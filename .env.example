# ── Django ───────────────────────────────────────────────
DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production-please
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ─────────────────────────────────
USE_POSTGRES=False
DB_NAME=qms
DB_USER=qms
DB_PASSWORD=qms_password
DB_HOST=db
DB_PORT=5432

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Telegram ─────────────────────────────────────────────
TOKEN=your-telegram-bot-token-here
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/bot/webhook/

# ── Media / Static ───────────────────────────────────────
MEDIA_URL=/media/
STATIC_URL=/static/
